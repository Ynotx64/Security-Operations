<group name="custom,edge,enterprise_runtime_v4,edge,vpn,validation,">

  <rule id="119550" level="8">
    <decoded_as>edge-vpn-validation-119540</decoded_as>
    <description>EDGE-VPN-001 IKE SA established on VPN gateway</description>
    <group>ike,strongswan,network</group>
  </rule>

  <rule id="119551" level="12">
    <if_sid>119550</if_sid>
    <match>first_seen_dst_ip_for_asset=true</match>
    <description>EDGE-VPN-002 first-seen remote peer for VPN gateway</description>
    <group>ike,first_seen,t1071</group>
    <options>alert_by_email</options>
  </rule>

  <rule id="119552" level="12">
    <if_sid>119550</if_sid>
    <match>in_maintenance_window=false</match>
    <description>EDGE-VPN-003 VPN tunnel established outside maintenance window</description>
    <group>afterhours,ike,t1078,t1133</group>
    <options>alert_by_email</options>
  </rule>

  <rule id="119553" level="15">
    <if_sid>119550</if_sid>
    <match>peer_reputation=unknown</match>
    <description>EDGE-VPN-004 VPN established with unknown or untrusted peer</description>
    <group>peer_risk,ike,t1071,t1041</group>
    <options>alert_by_email</options>
  </rule>

</group>
