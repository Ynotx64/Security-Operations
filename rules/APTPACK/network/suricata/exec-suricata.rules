alert http $HOME_NET any -> $EXTERNAL_NET any (
    msg:"APTPACK EXEC Script Download Followed By Command Pattern";
    flow:to_server,established;
    http.uri; pcre:"/(\.ps1|\.bat|\.sh|cmd=|exec=|run=)/Ui";
    classtype:attempted-admin;
    sid:700101;
    rev:1;
    metadata:mitre_tactic TA0002, phase EXEC, severity high;
)
