alert http $EXTERNAL_NET any -> $HOME_NET any (
    msg:"APTPACK IA User-Agent Missing On Auth Request";
    flow:to_server,established;
    http.method; content:"POST";
    http.uri; pcre:"/\/(login|signin|auth|session)/Ui";
    pcre:!"User-Agent\x3a/smi";
    classtype:bad-unknown;
    sid:700002;
    rev:1;
    metadata:mitre_tactic TA0001, phase IA, anti_bypass true, severity medium;
)
