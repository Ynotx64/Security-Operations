<group name="aptpack,solarwinds,postcompromise,credential_access,">

  <rule id="100800" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(rundll32|regsvr32|cmd|powershell|wmic|mshta|wscript|cscript|procdump|taskmgr)\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(lsass|MiniDump|comsvcs\.dll|sekurlsa|logonpasswords)</field>
    <description>SOLARWINDS-CA-001 Suspicious LSASS credential dumping command pattern</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>solarwinds,postcompromise,credential_access,lsass_dumping,t1003.001,</group>
  </rule>

  <rule id="100801" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(procdump.*-ma.*lsass|rundll32.*comsvcs\.dll.*MiniDump|sekurlsa::logonpasswords)</field>
    <description>SOLARWINDS-CA-002 Command line strongly consistent with LSASS dump attempt</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>solarwinds,postcompromise,credential_access,lsass_dumping,t1003.001,</group>
  </rule>

  <rule id="100802" level="11">
    <if_group>sysmon_event7</if_group>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)\\(dbghelp|comsvcs|vaultcli)\.dll$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(rundll32|powershell|cmd|wmic|regsvr32|procdump)\.exe$</field>
    <description>SOLARWINDS-CA-003 Suspicious credential-access-related DLL load</description>
    <mitre>
      <id>T1003</id>
      <id>T1218</id>
    </mitre>
    <group>solarwinds,postcompromise,credential_access,dll_load,t1003,t1218,</group>
  </rule>

  <rule id="100803" level="13" frequency="2" timeframe="300">
    <if_matched_sid>100800</if_matched_sid>
    <description>SOLARWINDS-CA-CORR-001 Repeated suspicious LSASS dump command patterns observed</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>solarwinds,postcompromise,credential_access,correlation,t1003.001,critical,</group>
  </rule>

  <rule id="100804" level="13" frequency="2" timeframe="300">
    <if_matched_sid>100801</if_matched_sid>
    <description>SOLARWINDS-CA-CORR-002 Repeated high-confidence LSASS dump attempts observed</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>solarwinds,postcompromise,credential_access,correlation,t1003.001,critical,</group>
  </rule>

</group>
