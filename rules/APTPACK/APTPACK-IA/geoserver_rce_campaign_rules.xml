<group name="aptpack,aptpack_ca,geoserver,web,">

  <rule id="100731" level="10">
    <if_sid>31100</if_sid>
    <url type="pcre2">(?i)^/geoserver/(web/|ows|wfs|wps|rest|j_spring_security_check)</url>
    <description>APTPACK-CA-GEOSERVER-001 GeoServer endpoint targeting observed</description>
    <group>aptpack,aptpack_ca,geoserver,web,targeting,t1190,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <rule id="100732" level="14">
    <if_sid>31100</if_sid>
    <url type="pcre2">(?i)^/geoserver/.*(exec\(|runtime|getruntime|processbuilder|java\.lang|\$\{|valueReference=)</url>
    <description>APTPACK-CA-GEOSERVER-002 GeoServer request contains exploit-like content</description>
    <group>aptpack,aptpack_ca,geoserver,web,exploit_attempt,t1190,high_severity,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <rule id="100733" level="15" frequency="2" timeframe="120">
    <if_matched_sid>100732</if_matched_sid>
    <same_srcip />
    <description>APTPACK-CA-GEOSERVER-CORR-001 Repeated GeoServer exploit-shaped requests from same source</description>
    <group>aptpack,aptpack_ca,geoserver,web,correlation,t1190,critical,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

</group>
