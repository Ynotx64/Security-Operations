<group name="honeypot,cowrie,tpot,">

  <rule id="111100" level="4">
    <match>cowrie</match>
    <description>Cowrie base event observed</description>
    <group>honeypot,tpot,cowrie,interactive_access,telemetry,</group>
  </rule>

  <rule id="111101" level="5">
    <match>cowrie</match>
    <match>SSH</match>
    <description>Cowrie SSH interaction observed</description>
    <group>cowrie,protocol_ssh,interactive_access,attribution_surface,</group>
  </rule>

  <rule id="111102" level="5">
    <match>cowrie</match>
    <match>telnet</match>
    <description>Cowrie Telnet interaction observed</description>
    <group>cowrie,protocol_telnet,interactive_access,attribution_surface,</group>
  </rule>

  <rule id="111110" level="6">
    <match>cowrie</match>
    <match>login attempt</match>
    <description>Cowrie authentication attempt observed</description>
    <group>cowrie,authentication,interaction,credential_access,</group>
    <mitre><id>T1110</id></mitre>
  </rule>

  <rule id="111111" level="8">
    <match>cowrie</match>
    <match>failed</match>
    <description>Cowrie failed authentication attempt observed</description>
    <group>cowrie,authentication_failed,bruteforce,credential_access,</group>
    <mitre><id>T1110</id></mitre>
  </rule>

  <rule id="111112" level="10">
    <match>cowrie</match>
    <match>succeeded</match>
    <description>Cowrie successful authentication observed</description>
    <group>cowrie,authentication_success,valid_account_use,post_auth,</group>
    <mitre><id>T1078</id></mitre>
  </rule>

  <rule id="111113" level="9">
    <match>cowrie</match>
    <match>session</match>
    <description>Cowrie session lifecycle event observed</description>
    <group>cowrie,session_open,interactive_access,connection_metadata,</group>
  </rule>

  <rule id="111114" level="10">
    <match>cowrie</match>
    <match>CMD:</match>
    <description>Cowrie command execution observed</description>
    <group>cowrie,command_execution,post_auth,execution,</group>
    <mitre><id>T1059</id></mitre>
  </rule>

  <rule id="111115" level="12">
    <match>cowrie</match>
    <match>wget </match>
    <description>Cowrie downloader or remote file retrieval behavior observed</description>
    <group>cowrie,file_download,payload_delivery,download_activity,</group>
    <mitre><id>T1105</id></mitre>
  </rule>

  <rule id="111116" level="11">
    <match>cowrie</match>
    <match>SHA256:</match>
    <description>Cowrie file artifact or upload observed</description>
    <group>cowrie,file_upload,artifact_capture,file_activity,</group>
    <mitre><id>T1105</id></mitre>
  </rule>

  <rule id="111120" level="12">
    <match>cowrie</match>
    <match>wget </match>
    <description>Cowrie downloader pattern detected</description>
    <group>cowrie,payload_delivery,downloader,malware_staging,</group>
    <mitre><id>T1105</id></mitre>
  </rule>

  <rule id="111121" level="12">
    <match>cowrie</match>
    <match>/bin/sh</match>
    <description>Cowrie shell execution or reverse shell pattern detected</description>
    <group>cowrie,shell_activity,post_auth,execution,reverse_shell,</group>
    <mitre><id>T1059</id></mitre>
  </rule>

  <rule id="111122" level="13">
    <match>cowrie</match>
    <match>xmrig</match>
    <description>Cowrie cryptominer deployment pattern detected</description>
    <group>cowrie,miner,resource_hijacking,attribution_candidate,crypto_mining,</group>
    <mitre><id>T1496</id></mitre>
  </rule>

  <rule id="111123" level="9">
    <match>cowrie</match>
    <match>root</match>
    <description>Cowrie default credential attempt detected</description>
    <group>cowrie,default_credentials,authentication_failed,credential_access,</group>
    <mitre><id>T1110</id></mitre>
  </rule>

  <rule id="111124" level="12">
    <match>cowrie</match>
    <match>solana</match>
    <description>Cowrie credential or actor theme related to crypto-node targeting observed</description>
    <group>cowrie,attribution_candidate,crypto_infra_targeting,credential_theme,</group>
  </rule>

  <rule id="111130" level="13" frequency="5" timeframe="300">
    <if_matched_group>cowrie,authentication_failed</if_matched_group>
    <same_source_ip />
    <description>Cowrie repeated failed authentication attempts from same source</description>
    <group>cowrie,bruteforce_burst,authentication_failed,credential_access,</group>
    <mitre><id>T1110</id></mitre>
  </rule>

  <rule id="111131" level="14" frequency="2" timeframe="300">
    <if_matched_group>cowrie,authentication_success</if_matched_group>
    <same_source_ip />
    <description>Cowrie successful authentication after prior activity from same source</description>
    <group>cowrie,success_after_fail,valid_account_use,attribution_candidate,</group>
    <mitre><id>T1078</id></mitre>
  </rule>

  <rule id="111140" level="12">
    <match>cowrie</match>
    <match>http://</match>
    <description>Cowrie URL IOC candidate observed</description>
    <group>cowrie,ioc_candidate,ioc_url,url_observed,threat_intel_enrichment,</group>
  </rule>

  <rule id="111141" level="12">
    <match>cowrie</match>
    <match>SHA256:</match>
    <description>Cowrie file hash IOC candidate observed</description>
    <group>cowrie,ioc_candidate,ioc_hash,hash_observed,threat_intel_enrichment,</group>
  </rule>

  <rule id="111142" level="10">
    <match>cowrie</match>
    <match>Remote SSH version</match>
    <description>Cowrie fingerprinting metadata observed for attribution</description>
    <group>cowrie,attribution_candidate,fingerprint_metadata,client_fingerprint,</group>
  </rule>

</group>