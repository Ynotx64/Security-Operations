<group name="honeypot,cowrie,tpot,">
  <rule id="111100" level="5"><match>cowrie</match><match>login attempt</match><description>Cowrie login attempt observed</description><group>authentication_failed,cowrie,ssh,telnet,</group><mitre><id>T1110</id></mitre></rule>
  <rule id="111101" level="8"><match>cowrie</match><regex>login attempt \[.*\] failed</regex><description>Cowrie failed authentication attempt</description><group>authentication_failed,bruteforce,cowrie,</group><mitre><id>T1110</id></mitre></rule>
  <rule id="111102" level="10"><match>cowrie</match><regex>login attempt \[.*\] succeeded|CMD:</regex><description>Cowrie successful access or command execution observed</description><group>authentication_success,cowrie,command_execution,</group><mitre><id>T1059</id></mitre></rule>
  <rule id="111103" level="12"><match>cowrie</match><regex>wget |curl |tftp |busybox|chmod \+x|/bin/sh|/bin/bash|nc |bash -i|sh -i</regex><description>Cowrie post-auth downloader or shell activity observed</description><group>payload_delivery,cowrie,malware,</group><mitre><id>T1105</id></mitre></rule>
</group>
