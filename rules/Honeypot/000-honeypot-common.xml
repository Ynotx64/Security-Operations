<group name="honeypot,tpot,common,">

  <rule id="111000" level="2">
    <decoded_as>json</decoded_as>
    <description>Structured honeypot event observed</description>
    <group>honeypot,tpot,telemetry,</group>
  </rule>

  <rule id="111001" level="3">
    <match>cowrie</match>
    <description>Honeypot taxonomy match: Cowrie</description>
    <group>honeypot,tpot,cowrie,interactive_access,ssh,telnet,</group>
  </rule>

  <rule id="111002" level="3">
    <match>dionaea</match>
    <description>Honeypot taxonomy match: Dionaea</description>
    <group>honeypot,tpot,dionaea,malware_capture,exploitation,</group>
  </rule>

  <rule id="111003" level="3">
    <match>heralding</match>
    <description>Honeypot taxonomy match: Heralding</description>
