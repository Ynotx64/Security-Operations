FROM logs-*, winlogbeat-*, filebeat-*, azure-*
| WHERE event.category == "authentication"
  AND event.outcome == "failure"
  AND user.roles LIKE "*admin*"
| STATS fail_count = COUNT(), src_ips = VALUES(source.ip), users = VALUES(user.name) BY DATE_TRUNC(15 minutes, @timestamp)
| WHERE fail_count >= 10
| SORT fail_count DESC
