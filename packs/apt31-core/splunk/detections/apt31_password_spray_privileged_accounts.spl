index=* (sourcetype=WinEventLog:Security OR sourcetype=azure:monitor:aad)
(event.outcome=failure OR ResultType!=0)
(user_role="admin" OR user="*admin*" OR user="*svc*")
| bucket _time span=15m
| stats count as fail_count values(src_ip) as src_ips values(user) as users by _time
| where fail_count>=10
| sort - fail_count
